# Copy this file to .env and fill it in. .env is git-ignored — never commit real secrets.

# Required. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# Production: leave DEBUG off. Set DEBUG=True only for local development.
DEBUG=False

# Your public hostname (the one DNS points at this server). Drives ALLOWED_HOSTS and the
# HTTPS CSRF origin, and tells Caddy which certificate to obtain. Example: lean.school.edu
PISA_DOMAIN=

# --- Optional ---------------------------------------------------------------------------

# Extra allowed hosts beyond PISA_DOMAIN (comma-separated). Usually unnecessary.
# ALLOWED_HOSTS=

# Create an admin account on first boot (no-op if it already exists). Otherwise run
# `docker compose -f docker-compose.prod.yml exec web python manage.py createsuperuser`.
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=

# Turn on HSTS once you're sure HTTPS is permanent for this domain (it's sticky).
# SECURE_HSTS_SECONDS=31536000

# Lean is baked into the image; docker-compose.prod.yml already points these at it. Only set
# them if you run the app outside the provided container.
# LEAN_LSP_CMD=lean --server
# LEAN_EXECUTABLE=lean

# Untrusted Lean runs FULLY sandboxed by default: bubblewrap (no network, read-only filesystem)
# plus a stripped environment, resource limits, and its own process group. The compose files
# already grant the seccomp profile bubblewrap needs inside Docker. Optional extra hard caps:
# LEAN_SANDBOX_MEMORY_MB=2048
# LEAN_SANDBOX_MAX_PROCESSES=64
# Disable the bubblewrap layer only on a host without it (leaves Lean with filesystem + network
# access — not recommended when serving untrusted users):
# LEAN_SANDBOX_WRAPPER=
